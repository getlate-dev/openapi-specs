                "schema": {
                  "type": "string",
                  "example": "Sat, 01 Jan 2000 00:00:00 GMT"
                }
              },
              "x-fb-request-id": {
                "schema": {
                  "type": "string",
                  "example": "A6-9Zr5dtxnkpc3tz2H8w6b"
                }
              },
              "x-fb-trace-id": {
                "schema": {
                  "type": "string",
